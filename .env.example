# ── WATT Energy Intelligence Platform — Environment Variables ─────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.

# ── EIA API ───────────────────────────────────────────────────────────────────
# Free key at: https://www.eia.gov/opendata/
EIA_API_KEY= 00aBsSmN4Zgw8lzttWIN8J2yBwAiiZfEUL0Hr6sy

# ── ENTSO-E API (optional — European data) ────────────────────────────────────
# Register at: https://transparency.entsoe.eu/
# Then request a Security Token from your profile page.
ENTSO_API_KEY=your_entso_api_key_here
# ── PostgreSQL (Day 8 — API metadata storage) ─────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=watt
POSTGRES_USER=watt_user
POSTGRES_PASSWORD=your_postgres_password_here

# ── MLflow (Day 5 — uses Databricks MLflow by default) ────────────────────────
# Leave empty to use Databricks-hosted MLflow (recommended)
# Set to a local URI for local development: mlflow/
MLFLOW_TRACKING_URI=

# ── Databricks (used by Databricks CLI / GitHub Actions) ─────────────────────
DATABRICKS_HOST=https://your-workspace.azuredatabricks.net
DATABRICKS_TOKEN=your_databricks_pat_here
